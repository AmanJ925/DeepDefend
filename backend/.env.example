# ============================================================
# DeepDefend Backend — Environment Variables
# ============================================================
# Copy this file to .env:  cp .env.example .env

# REQUIRED for AI-generated narrative reports (Google Gemini)
# Get a FREE key at: https://aistudio.google.com/app/apikey
# The app WORKS without this — uses a rule-based fallback report.
GOOGLE_API_KEY=your_gemini_api_key_here